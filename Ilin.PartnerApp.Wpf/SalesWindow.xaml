<Window x:Class="Ilin.PartnerApp.Wpf.SalesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ilin.PartnerApp.Wpf"
        mc:Ignorable="d"
        Title="Продажи" Height="600" Width="1200"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                CornerRadius="6"
                BorderBrush="#D0D0D0"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddButton"
                        Width="120"
                        Height="35"
                        Margin="0,0,10,0"
                        Content="Добавить"
                        Click="AddButton_Click"/>

                <Button x:Name="EditButton"
                        Width="120"
                        Height="35"
                        Margin="0,0,10,0"
                        Content="Изменить"
                        Click="EditButton_Click"/>

                <Button x:Name="DeleteButton"
                        Width="120"
                        Height="35"
                        Margin="0,0,10,0"
                        Content="Удалить"
                        Click="DeleteButton_Click"/>

                <Button x:Name="RefreshButton"
                        Width="120"
                        Height="35"
                        Content="Обновить"
                        Click="RefreshButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Padding="10"
                CornerRadius="6"
                BorderBrush="#D0D0D0"
                BorderThickness="1">
            <DataGrid x:Name="SalesDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="30"/>
                    <DataGridTextColumn Header="Партнер" Binding="{Binding PartnerName}" Width="150"/>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="150"/>
                    <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding SaleDate}" Width="100"/>
                    <DataGridTextColumn Header="Базовая цена" Binding="{Binding BasePrice, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Скидка, %" Binding="{Binding DiscountPercent}" Width="80"/>
                    <DataGridTextColumn Header="Цена продажи" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
