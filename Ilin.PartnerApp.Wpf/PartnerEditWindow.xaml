<Window x:Class="Ilin.PartnerApp.Wpf.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ilin.PartnerApp.Wpf"
        mc:Ignorable="d"
        Title="PartnerEditWindow" Height="660" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="15"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.ColumnSpan="2"
                           Text="Карточка партнера"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Тип партнера:"/>
                <ComboBox x:Name="PartnerTypeComboBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          Height="30"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Наименование:"/>
                <TextBox x:Name="CompanyNameTextBox"
                         Grid.Row="4"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Адрес:"/>
                <TextBox x:Name="AddressTextBox"
                         Grid.Row="6"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="ИНН:"/>
                <TextBox x:Name="InnTextBox"
                         Grid.Row="8"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="10"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="ФИО директора:"/>
                <TextBox x:Name="DirectorFullnameTextBox"
                         Grid.Row="10"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="12"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Телефон:"/>
                <TextBox x:Name="PhoneTextBox"
                         Grid.Row="12"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="14"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Email:"/>
                <TextBox x:Name="EmailTextBox"
                         Grid.Row="14"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="16"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Рейтинг:"/>
                <TextBox x:Name="RatingTextBox"
                         Grid.Row="16"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="18"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Путь к логотипу:"/>
                <TextBox x:Name="LogoPathTextBox"
                         Grid.Row="18"
                         Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="20"
                           Grid.Column="0"
                           VerticalAlignment="Top"
                           Text="Места продаж:"/>
                <TextBox x:Name="SalesPlacesTextBox"
                         Grid.Row="20"
                         Grid.Column="1"
                         Height="70"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="10"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <TextBlock x:Name="StatusTextBlock"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="DimGray"
                           Text=""/>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="SaveButton"
                            Width="120"
                            Height="35"
                            Margin="0,0,10,0"
                            Content="Сохранить"
                            Click="SaveButton_Click"/>

                    <Button x:Name="CancelButton"
                            Width="120"
                            Height="35"
                            Content="Отмена"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
